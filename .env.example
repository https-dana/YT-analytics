# --- Google OAuth (console.cloud.google.com -> APIs & Services -> Credentials) ---
# Create an "OAuth 2.0 Client ID" of type "Web application".
# Authorized redirect URI must be: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Base URL of this app (used to build the OAuth redirect URI)
APP_URL=http://localhost:3000

# Enable required APIs in Google Cloud Console for your project:
#   - YouTube Data API v3
#   - YouTube Analytics API

# --- Mock mode ---
# When true (default), the app runs entirely on generated fake data so the
# whole UI/UX can be reviewed without any Google credentials.
# Set to "false" once GOOGLE_CLIENT_ID/SECRET above are filled in, to hit
# the real YouTube Data API + YouTube Analytics API.
MOCK_MODE=true

# --- Persistence ---
# Where connected-channel data (incl. tokens) is stored, as a flat JSON file.
# On platforms with an ephemeral filesystem (Railway, Heroku, etc.) point
# this at a mounted persistent volume, e.g. /data, or the store resets on
# every deploy/restart. Defaults to ./data if unset.
# DATA_DIR=/data
